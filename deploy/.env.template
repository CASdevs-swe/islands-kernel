# islands-kernel served-kernel environment — TEMPLATE
#
# Copy to a host-only file (never committed) and fill in.
#   cp deploy/.env.template /etc/islands-kernel/kernel.env
#   chmod 0600 /etc/islands-kernel/kernel.env
# Point KERNEL_ENV_FILE at that path for pm2 and the deploy script.
#
# Every var in docs/kernel-integration.md "Env matrix" is represented here.
# The two crown jewels (KERNEL_SIGNING_SEED, VAULT_KEK) are left as REQUIRED
# placeholders and MUST be supplied from the host secret store / KMS, never
# written into a committed file. See the custody note at the bottom.

# ── topology (host / domains / ports) ───────────────────────────────────────
# Services bind loopback only; Caddy terminates TLS and reverse-proxies in.
BIND_HOST=127.0.0.1
IDENTITY_PORT=8081
VAULT_PORT=8082
BUS_PORT=8083

# Public hostnames Caddy serves (one subdomain per service).
KERNEL_ID_DOMAIN=id.example.com
KERNEL_VAULT_DOMAIN=vault.example.com
KERNEL_BUS_DOMAIN=bus.example.com
# ACME contact for Caddy's automatic TLS.
ACME_EMAIL=ops@example.com

# ── shared kernel identity (all three services) ─────────────────────────────
# Issuer is the public identity URL; JWKS hangs off it. Keep these consistent.
KERNEL_ISSUER=https://id.example.com
KERNEL_JWKS_URL=https://id.example.com/.well-known/jwks.json
KERNEL_KID=kid-1
# Identity writes this sqlite; vault and bus read grants from it. Same path,
# all three services. Lives under a 0700 host state dir, gitignored pattern.
KERNEL_IDENTITY_DB=/var/lib/islands-kernel/identity.sqlite

# ── identity service ────────────────────────────────────────────────────────
IDENTITY_BOOT=1
# REQUIRED — base64url Ed25519 32-byte seed. Crown jewel. From host secret
# store / KMS only. Generate a throwaway dev one with:
#   python -c "from identity.tokens import b64url; import os; print(b64url(os.urandom(32)))"
KERNEL_SIGNING_SEED=REQUIRED__set_from_host_secret_store

# ── vault service ───────────────────────────────────────────────────────────
VAULT_BOOT=1
VAULT_BACKEND=server
VAULT_REQUIRE_KERNEL=1
VAULT_AUDIENCE=vault
VAULT_DB=sqlite:////var/lib/islands-kernel/vault.sqlite
# REQUIRED — base64 32-byte KEK. Crown jewel. From host secret store / KMS only.
# Generate a throwaway dev one with:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
VAULT_KEK=REQUIRED__set_from_host_secret_store
# HMAC key for OAuth state signing on the connect flow (not a token secret).
VAULT_STATE_HMAC_KEY=change-me-host-only

# Provider app credentials. Needed for the vault to mint/refresh provider tokens.
# These are the OAuth *app* client id/secret, set on the host only. Left empty in
# the template; the gated live-Fortnox connect step is where these first matter.
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_REDIRECT_URI=
FORTNOX_SCOPES=

# ── bus service ─────────────────────────────────────────────────────────────
BUS_BOOT=1
BUS_AUDIENCE=bus
BUS_DB=sqlite:////var/lib/islands-kernel/bus.sqlite
# Event-data schema registry seed (schema_id -> JSON Schema). Without it the bus
# rejects every publish at validation. Ships in-repo at deploy/schemas.json.
BUS_SCHEMAS_FILE=/opt/islands-kernel/deploy/schemas.json

# ── optional: post-deploy principal provisioning ────────────────────────────
# If set, the deploy script issues ONE multi-service principal for an ALREADY
# EXISTING connection (created earlier via the gated connect flow) and writes the
# raw credential to a 0600 file under the state dir. Leave unset on first deploy;
# there is no connection to grant against until the gated connect step has run.
KERNEL_PROVISION_PRINCIPAL=
KERNEL_PROVISION_ORG=
KERNEL_PROVISION_CONNECTION=
KERNEL_PROVISION_EVENT_TYPE=bookkeeping.voucher.posted
KERNEL_PROVISION_GRANTED_BY=prn_owner
KERNEL_PROVISION_TTL_DAYS=90

# ── secret custody / rotation ───────────────────────────────────────────────
# KERNEL_SIGNING_SEED and VAULT_KEK are the only crown jewels. Keep them in the
# host secret store / KMS and inject at boot; never commit, never log.
#  - Rotating VAULT_KEK requires re-sealing every envelope (decrypt with the old
#    KEK, re-seal with the new). Plan a maintenance window.
#  - Rotating the signing seed uses publish-before-sign JWKS overlap: add the new
#    key to the JWKS document, let verifiers cache it, then sign with it.
