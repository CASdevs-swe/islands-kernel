# islands-kernel served-kernel environment — caputventi.com FILLED EXAMPLE.
#
# Derived from deploy/.env.template with the resolved caputventi.com values
# (runbook: islands-platform/specs/2026-06-20-kernel-deploy-runbook.md). The
# kernel is cross-island org infra, NOT a SmartCharge feature, so it lives under
# caputventi.com, not smartcharge.nu.
#
# This is an EXAMPLE, not the live env file. On the host:
#   cp deploy/kernel.env.caputventi.example /etc/islands-kernel/kernel.env
#   chmod 0600 /etc/islands-kernel/kernel.env
#   # then fill KERNEL_SIGNING_SEED + VAULT_KEK from the host secret store
# Point KERNEL_ENV_FILE at that path for pm2 and the deploy script.
# The two crown jewels stay REQUIRED placeholders here — never real values.

# ── topology (host / domains / ports) ───────────────────────────────────────
# Services bind loopback only; the box's nginx terminates TLS and proxies in.
BIND_HOST=127.0.0.1
IDENTITY_PORT=8081
VAULT_PORT=8082
BUS_PORT=8083

# Public hostnames the proxy serves (one subdomain per service).
KERNEL_ID_DOMAIN=id.caputventi.com
KERNEL_VAULT_DOMAIN=vault.caputventi.com
KERNEL_BUS_DOMAIN=bus.caputventi.com
# ACME contact — unused on this box (existing nginx + its existing certs handle
# TLS; no Caddy/ACME here). Kept for env-matrix completeness.
ACME_EMAIL=ops@caputventi.com

# ── shared kernel identity (all three services) ─────────────────────────────
KERNEL_ISSUER=https://id.caputventi.com
KERNEL_JWKS_URL=https://id.caputventi.com/.well-known/jwks.json
KERNEL_KID=kid-1
KERNEL_IDENTITY_DB=/var/lib/islands-kernel/identity.sqlite

# ── identity service ────────────────────────────────────────────────────────
IDENTITY_BOOT=1
# REQUIRED — base64url Ed25519 32-byte seed. Crown jewel. From host secret
# store / KMS only; never written into this file in the repo.
KERNEL_SIGNING_SEED=REQUIRED__set_from_host_secret_store

# ── vault service ───────────────────────────────────────────────────────────
VAULT_BOOT=1
VAULT_BACKEND=server
VAULT_REQUIRE_KERNEL=1
# Audience the vault enforces; must equal the `aud` the issued JWT carries.
VAULT_AUDIENCE=https://vault.caputventi.com
VAULT_DB=sqlite:////var/lib/islands-kernel/vault.sqlite
# REQUIRED — base64 32-byte KEK. Crown jewel. From host secret store / KMS only.
VAULT_KEK=REQUIRED__set_from_host_secret_store
# HMAC key for OAuth state signing on the connect flow (not a token secret).
VAULT_STATE_HMAC_KEY=change-me-host-only

# Provider OAuth *app* credentials. Left empty until the gated live-Fortnox
# connect step — that is where these first matter. Do not pre-fill.
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_REDIRECT_URI=
FORTNOX_SCOPES=

# ── bus service ─────────────────────────────────────────────────────────────
BUS_BOOT=1
# Audience the bus enforces; must equal the `aud` the issued JWT carries.
BUS_AUDIENCE=https://bus.caputventi.com
BUS_DB=sqlite:////var/lib/islands-kernel/bus.sqlite
# Event-data schema registry seed. Without it the bus rejects every publish.
BUS_SCHEMAS_FILE=/opt/islands-kernel/deploy/schemas.json

# ── optional: post-deploy principal provisioning ────────────────────────────
# Leave unset on first deploy; there is no connection to grant against until the
# gated connect step has run.
KERNEL_PROVISION_PRINCIPAL=
KERNEL_PROVISION_ORG=
KERNEL_PROVISION_CONNECTION=
KERNEL_PROVISION_EVENT_TYPE=bookkeeping.voucher.posted
KERNEL_PROVISION_GRANTED_BY=prn_owner
KERNEL_PROVISION_TTL_DAYS=90

# ── secret custody / rotation ───────────────────────────────────────────────
# KERNEL_SIGNING_SEED and VAULT_KEK are the only crown jewels. Host secret
# store / KMS only; inject at boot; never commit, never log.
#  - Rotating VAULT_KEK requires re-sealing every envelope. Plan a window.
#  - Rotating the signing seed uses publish-before-sign JWKS overlap.
